<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme — minimal, Compose handles all UI theming -->
    <style name="Theme.Fishing" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.AnimatedSplashScreen" parent="Theme.Fishing" />

    <style name="Theme.AppSplash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/icon_splashscreen</item>
        <item name="android:windowSplashScreenBrandingImage" tools:targetApi="s">@drawable/ic_fish</item>
        <item name="postSplashScreenTheme">@style/Theme.AnimatedSplashScreen</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
